{
  "version": "rules/2",
  "keyNormalization": "camel_to_snake",
  "keyPatterns": [
    {
      "id": "sensitive-key",
      "description": "Object keys that denote credentials; their values are replaced wholesale.",
      "pattern": "(^|[_-])(authorization|auth|api[_-]?key|access[_-]?(?:key|token)|refresh[_-]?token|client[_-]?secret|token|secret|password|pwd|pass|credential|private[_-]?key|session[_-]?key)($|[_-])",
      "caseInsensitive": true,
      "provenance": "structural"
    }
  ],
  "valuePatterns": [
    {
      "id": "private-key-block",
      "description": "PEM private key blocks.",
      "pattern": "-----BEGIN [A-Z ]*PRIVATE KEY-----[\\s\\S]*?-----END [A-Z ]*PRIVATE KEY-----",
      "caseInsensitive": false,
      "provenance": "gitleaks:private-key"
    },
    {
      "id": "authorization-header",
      "description": "Authorization header values, with or without an authentication scheme.",
      "pattern": "\\b(Authorization\\s*:\\s*(?:(?:Bearer|Basic)\\s+)?)(?:\"(?:\\\\.|[^\"\\\\])*\"|'[^']*'|`(?:\\\\.|[^`\\\\])*`|[^\\s&;|)\"'`]+|[\"'`]\\S+)+",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "bearer-auth",
      "description": "Bearer authorization values of any non-empty length; fallback for non-header contexts. authorization-header runs first, so re-matching its placeholder output in header context is an intentional idempotent overlap.",
      "pattern": "\\b(Bearer\\s+)(?:\"(?:\\\\.|[^\"\\\\])*\"|'[^']*'|`(?:\\\\.|[^`\\\\])*`|[^\\s&;|)\"'`]+|[\"'`]\\S+)+",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "basic-auth",
      "description": "Bare Basic authorization values shaped like credentials (8+ token characters); header context of any length is covered by authorization-header.",
      "pattern": "\\b(Basic\\s+)[A-Za-z0-9._~+/=-]{8,}",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "github-token",
      "description": "GitHub classic tokens (ghp/gho/ghu/ghs/ghr).",
      "pattern": "\\b(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{16,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:github-pat"
    },
    {
      "id": "github-fine-grained-pat",
      "description": "GitHub fine-grained personal access tokens.",
      "pattern": "\\bgithub_pat_[A-Za-z0-9_]{16,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:github-fine-grained-pat"
    },
    {
      "id": "openai-api-key",
      "description": "OpenAI-style secret keys.",
      "pattern": "\\bsk-(?:proj-)?[A-Za-z0-9_-]{16,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:openai-api-key"
    },
    {
      "id": "aws-access-key-id",
      "description": "AWS access key identifiers.",
      "pattern": "\\b(?:AKIA|ASIA)[A-Z0-9]{16}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:aws-access-token"
    },
    {
      "id": "slack-token",
      "description": "Slack bot/app/user tokens.",
      "pattern": "\\bxox[baprs]-[A-Za-z0-9-]{16,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:slack-bot-token"
    },
    {
      "id": "npm-token",
      "description": "npm access tokens.",
      "pattern": "\\bnpm_[A-Za-z0-9]{16,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:npm-access-token"
    },
    {
      "id": "gcp-api-key",
      "description": "Google Cloud API keys.",
      "pattern": "\\bAIza[0-9A-Za-z_-]{20,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:gcp-api-key"
    },
    {
      "id": "jwt",
      "description": "JSON Web Tokens.",
      "pattern": "\\beyJ[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b",
      "caseInsensitive": false,
      "provenance": "gitleaks:jwt"
    },
    {
      "id": "url-userinfo",
      "description": "Credentials embedded in URLs (scheme plus userinfo up to and including the @).",
      "pattern": "https?://[^/?#\\s\"'<>@]+@",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "json-sensitive-property",
      "description": "String values of credential-bearing properties in JSON embedded in flat text.",
      "pattern": "(\"(?:[A-Za-z0-9_-]*(?:api[_-]?key|access[_-]?(?:key|token)|refresh[_-]?token|client[_-]?secret|token|secret|password|passwd|credential|private[_-]?key)[A-Za-z0-9_-]*|(?:[A-Za-z0-9]+[_-])*(?:pwd|pass)(?:[_-][A-Za-z0-9]+)*)\"\\s*:\\s*)\"(?:\\\\.|[^\"\\\\])*\"",
      "replacement": "$1\"[REDACTED_SECRET]\"",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "sensitive-assignment",
      "description": "key=value / key: value assignments where the key names a credential.",
      "pattern": "\\b((?:[A-Za-z0-9_-]*(?:api[_-]?key|access[_-]?(?:key|token)|refresh[_-]?token|client[_-]?secret|token|secret|password|passwd|credential|private[_-]?key)[A-Za-z0-9_-]*|(?:[A-Za-z0-9]+[_-])*(?:pwd|pass)(?:[_-][A-Za-z0-9]+)*)\\s*[:=]\\s*)(?:\"(?:\\\\.|[^\"\\\\])*\"|'[^']*'|`(?:\\\\.|[^`\\\\])*`|[^\\s&;|)\"'`]+|[\"'`]\\S+)+",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "sensitive-cli-flag",
      "description": "CLI flags carrying credentials (--token x, --token=x).",
      "pattern": "(--(?:api[-_]?key|access[-_]?(?:key|token)|refresh[-_]?token|client[-_]?secret|token|secret|password|pwd|pass|credential|private[-_]?key)[= ])(?:\"(?:\\\\.|[^\"\\\\])*\"|'[^']*'|`(?:\\\\.|[^`\\\\])*`|[^\\s&;|)\"'`]+|[\"'`]\\S+)+",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "basic-auth-userinfo",
      "description": "user:password credentials passed to command-line -u/--user flags.",
      "pattern": "((?:^|\\s)(?:-u|--user)(?:=|\\s+))(?:\"(?:\\\\.|[^\"\\\\])*:[^\"]*\"|'[^']*:[^']*'|[^\\s:]+:[^\\s&;|)]+)",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    },
    {
      "id": "sensitive-query-param",
      "description": "Credential-bearing URL query parameters.",
      "pattern": "([?&](?:access[-_]?token|api[-_]?key|client[-_]?secret|code|key|password|pwd|pass|refresh[-_]?token|secret|token)=)[^&\\s\"']+",
      "replacement": "$1[REDACTED_SECRET]",
      "caseInsensitive": true,
      "provenance": "structural"
    }
  ]
}
