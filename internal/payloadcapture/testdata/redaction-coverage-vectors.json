{
  "valueVectors": [
    {
      "name": "pem-private-key",
      "ruleId": "private-key-block",
      "input": "config:\n-----BEGIN RSA PRIVATE KEY-----\nMIIfakekeymaterialFAKE\n-----END RSA PRIVATE KEY-----\ndone",
      "mustNotSurvive": ["MIIfakekeymaterialFAKE"]
    },
    {
      "name": "bearer-header",
      "ruleId": "bearer-auth",
      "input": "echo Bearer abc123",
      "mustNotSurvive": ["abc123"],
      "expected": "echo Bearer [REDACTED_SECRET]"
    },
    {
      "name": "bare-basic-auth",
      "ruleId": "basic-auth",
      "input": "echo Basic dXNlcjpwYXNzd29yZA== done",
      "mustNotSurvive": ["dXNlcjpwYXNzd29yZA=="],
      "expected": "echo Basic [REDACTED_SECRET] done"
    },
    {
      "name": "plain-authorization-header",
      "ruleId": "authorization-header",
      "input": "curl -H \"Authorization: header-secret-FAKE\" https://api.example.test",
      "mustNotSurvive": ["header-secret-FAKE"],
      "expected": "curl -H \"Authorization: [REDACTED_SECRET]\" https://api.example.test"
    },
    {
      "name": "github-classic-token",
      "ruleId": "github-token",
      "input": "GITHUB_TOKEN is ghp_FAKE0123456789abcdefFAKE here",
      "mustNotSurvive": ["ghp_FAKE0123456789abcdefFAKE"]
    },
    {
      "name": "github-fine-grained-pat",
      "ruleId": "github-fine-grained-pat",
      "input": "use github_pat_11FAKEFAKE0123456789abcdef for auth",
      "mustNotSurvive": ["github_pat_11FAKEFAKE0123456789abcdef"]
    },
    {
      "name": "openai-style-key",
      "ruleId": "openai-api-key",
      "input": "OPENAI key sk-proj-FAKEabcdefghijklmnop1234",
      "mustNotSurvive": ["sk-proj-FAKEabcdefghijklmnop1234"]
    },
    {
      "name": "aws-access-key-id",
      "ruleId": "aws-access-key-id",
      "input": "aws configure set aws_access_key_id AKIAFAKEFAKEFAKEFAKE",
      "mustNotSurvive": ["AKIAFAKEFAKEFAKEFAKE"]
    },
    {
      "name": "slack-bot-token",
      "ruleId": "slack-token",
      "input": "SLACK_BOT_TOKEN xoxb-FAKE123456-FAKEabcdefghij",
      "mustNotSurvive": ["xoxb-FAKE123456-FAKEabcdefghij"]
    },
    {
      "name": "npm-token",
      "ruleId": "npm-token",
      "input": "//registry.npmjs.org/:_authToken=npm_FAKEabcdefghijklmnop12",
      "mustNotSurvive": ["npm_FAKEabcdefghijklmnop12"]
    },
    {
      "name": "gcp-api-key",
      "ruleId": "gcp-api-key",
      "input": "maps client key AIzaFAKE1234567890abcdefghij end",
      "mustNotSurvive": ["AIzaFAKE1234567890abcdefghij"]
    },
    {
      "name": "jwt",
      "ruleId": "jwt",
      "input": "session eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjM0In0.FAKEsignatureFAKE1234",
      "mustNotSurvive": [
        "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjM0In0.FAKEsignatureFAKE1234"
      ]
    },
    {
      "name": "url-userinfo",
      "ruleId": "url-userinfo",
      "input": "git clone https://deploy:hunter2FAKEpass@git.example.test/repo.git",
      "mustNotSurvive": ["hunter2FAKEpass"]
    },
    {
      "name": "env-assignment",
      "ruleId": "sensitive-assignment",
      "input": "GITHUB_TOKEN=verysecretFAKEvalue gh api /user",
      "mustNotSurvive": ["verysecretFAKEvalue"],
      "expected": "GITHUB_TOKEN=[REDACTED_SECRET] gh api /user"
    },
    {
      "name": "assignment-preserves-shell-separator",
      "ruleId": "sensitive-assignment",
      "input": "printf ok;ACCESS_KEY=access-secret-FAKE echo next",
      "mustNotSurvive": ["access-secret-FAKE"],
      "expected": "printf ok;ACCESS_KEY=[REDACTED_SECRET] echo next"
    },
    {
      "name": "password-alias-assignment",
      "ruleId": "sensitive-assignment",
      "input": "PASS=pass-secret-FAKE login",
      "mustNotSurvive": ["pass-secret-FAKE"],
      "expected": "PASS=[REDACTED_SECRET] login"
    },
    {
      "name": "delimited-pass-segment-assignment",
      "ruleId": "sensitive-assignment",
      "input": "DB_PASS=db-secret-FAKE deploy",
      "mustNotSurvive": ["db-secret-FAKE"],
      "expected": "DB_PASS=[REDACTED_SECRET] deploy"
    },
    {
      "name": "passwd-assignment",
      "ruleId": "sensitive-assignment",
      "input": "PASSWD=passwd-secret-FAKE su",
      "mustNotSurvive": ["passwd-secret-FAKE"],
      "expected": "PASSWD=[REDACTED_SECRET] su"
    },
    {
      "name": "assignment-unclosed-quote",
      "ruleId": "sensitive-assignment",
      "input": "TOKEN=\"unterminated-secret-FAKE",
      "mustNotSurvive": ["unterminated-secret-FAKE"],
      "expected": "TOKEN=[REDACTED_SECRET]"
    },
    {
      "name": "assignment-unclosed-quote-mid-value",
      "ruleId": "sensitive-assignment",
      "input": "TOKEN=a\"broken-secret-FAKE deploy",
      "mustNotSurvive": ["broken-secret-FAKE"],
      "expected": "TOKEN=[REDACTED_SECRET] deploy"
    },
    {
      "name": "json-embedded-password",
      "ruleId": "json-sensitive-property",
      "input": "curl -d '{\"password\":\"json-secret-FAKE\",\"name\":\"safe\"}'",
      "mustNotSurvive": ["json-secret-FAKE"],
      "expected": "curl -d '{\"password\":\"[REDACTED_SECRET]\",\"name\":\"safe\"}'"
    },
    {
      "name": "cli-flag-space",
      "ruleId": "sensitive-cli-flag",
      "input": "mytool login --password hunter2FAKEsecret --verbose",
      "mustNotSurvive": ["hunter2FAKEsecret"],
      "expected": "mytool login --password [REDACTED_SECRET] --verbose"
    },
    {
      "name": "curl-user-password",
      "ruleId": "basic-auth-userinfo",
      "input": "curl -u user:curl-secret-FAKE https://api.example.test",
      "mustNotSurvive": ["user:curl-secret-FAKE", "curl-secret-FAKE"],
      "expected": "curl -u [REDACTED_SECRET] https://api.example.test"
    },
    {
      "name": "query-param-code",
      "ruleId": "sensitive-query-param",
      "input": "GET /callback?code=authcodeFAKEsecret&state=xyz",
      "mustNotSurvive": ["authcodeFAKEsecret"],
      "expected": "GET /callback?code=[REDACTED_SECRET]&state=xyz"
    }
  ],
  "keyVectors": [
    { "name": "camel-api-key", "key": "apiKey", "sensitive": true },
    { "name": "authorization", "key": "Authorization", "sensitive": true },
    {
      "name": "snake-refresh-token",
      "key": "refresh_token",
      "sensitive": true
    },
    { "name": "camel-client-secret", "key": "clientSecret", "sensitive": true },
    { "name": "dashed-api-key", "key": "x-api-key", "sensitive": true },
    { "name": "session-key", "key": "sessionKey", "sensitive": true },
    { "name": "access-key", "key": "accessKey", "sensitive": true },
    { "name": "password-alias", "key": "pwd", "sensitive": true },
    { "name": "author-is-not-auth", "key": "author", "sensitive": false },
    {
      "name": "tokenizer-is-not-token",
      "key": "tokenizer",
      "sensitive": false
    },
    { "name": "plain-command", "key": "command", "sensitive": false }
  ]
}
